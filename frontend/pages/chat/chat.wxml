<view class="container">
  <!-- 顶部导航 -->
  <view class="safe-area-top"></view>
  <view class="chat-header">
    <view class="header-content">
      <view class="back-btn" bindtap="handleBack">
        <text class="cuIcon-back"></text>
      </view>
      <view class="user-info">
        <image 
          class="chat-avatar" 
          src="{{avatar}}" 
          binderror="handleImageError" 
          data-type="avatar"
          mode="aspectFill"
        />
        <view class="user-detail">
          <text class="chat-username">{{username}}</text>
          <text class="user-status">在线</text>
        </view>
      </view>
      <view class="header-actions">
        <view class="action-btn">
          <text class="cuIcon-more"></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 聊天消息列表 -->
  <scroll-view class="chat-box" scroll-y="true" scroll-into-view="msg-{{chatMessages.length-1}}">
    <block wx:for="{{chatMessages}}" wx:key="id">
      <!-- 日期分割线 - 按日期分组显示 -->
      <view class="message-date" wx:if="{{item.showDateLine}}">
        <text>{{item.dateString}}</text>
      </view>
      
      <view class="chat-item {{item.isSelf ? 'self' : 'other'}}" id="msg-{{index}}">
        <image 
          class="chat-avatar" 
          src="{{item.tempAvatar || (item.isSelf ? userAvatar : avatar)}}" 
          binderror="handleImageError"
          data-type="{{item.isSelf ? 'user-avatar' : 'avatar'}}"
          data-index="{{index}}"
          mode="aspectFill"
        />
        <view class="chat-content">
          <text>{{item.content}}</text>
          <text class="chat-time">{{item.timeString}}</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 底部输入框 -->
  <view class="chat-input">
    <input 
      class="input-box" 
      bindinput="onInput" 
      value="{{inputText}}" 
      placeholder="请输入消息..." 
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>
</view>
