.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f8f8;
}

/* 头部导航 */
.chat-header {
  display: flex;
  align-items: center;
  padding: 15px;
  background: #ff4d6a;
  color: white;
  font-size: 18px;
}

.chat-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  margin-right: 10px;
}

/* 聊天框 */
.chat-box {
  flex: 1;
  padding: 10px;
  overflow-y: scroll;
}

/* 聊天消息 */
.chat-item {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.chat-item.self {
  justify-content: flex-end;
}

.chat-item.other {
  justify-content: flex-start;
}

.chat-content {
  max-width: 60%;
  padding: 10px;
  border-radius: 10px;
  background: #e6e6e6;
}

.self .chat-content {
  background: #ff4d6a;
  color: white;
}

/* 底部输入框 */
.chat-input {
  display: flex;
  align-items: center;
  padding: 10px;
  background: white;
  border-top: 1px solid #ddd;
}

.input-box {
  flex: 1;
  padding: 8px;
  border: 1px solid #ddd;
  border-radius: 5px;
  margin-right: 10px;
}

.send-btn {
  background: #ff4d6a;
  color: white;
  padding: 8px 15px;
  border-radius: 5px;
}
