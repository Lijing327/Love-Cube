/* 页面整体 */
.container {
  min-height: 100vh;
  background: #f7f8f9;
}

/* 导航栏 */
.nav-bar {
  background: #fff;
  padding-top: 88rpx; /* 状态栏高度 */
  border-bottom: 2rpx solid #f7f8f9;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-bar-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.post-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 动态列表 */
.dynamic-list {
  margin-top: 176rpx; /* 导航栏高度 */
  height: calc(100vh - 176rpx);
}

.dynamic-item {
  margin-bottom: 20rpx;
  background: #fff;
  padding: 30rpx;
}

/* 用户信息 */
.user-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-basic {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

/* 动态内容 */
.content {
  margin-bottom: 20rpx;
}

.text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.image-list {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dynamic-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
}

.single-image {
  width: 440rpx;
  height: 440rpx;
}

.location {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.location text {
  margin-left: 8rpx;
}

/* 互动栏 */
.interaction-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-top: 2rpx solid #f7f8f9;
  border-bottom: 2rpx solid #f7f8f9;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-item text {
  font-size: 26rpx;
  color: #999;
}

.action-item text.active {
  color: #ff4d6a;
}

/* 评论区 */
.comment-preview {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f7f8f9;
  border-radius: 12rpx;
}

.comment-item {
  margin-bottom: 16rpx;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.comment-content {
  font-size: 26rpx;
  color: #666;
}

.view-more {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding-top: 16rpx;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 评论输入框 */
.comment-input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #f7f8f9;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.submit-btn {
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 30rpx;
}

.submit-btn.active {
  color: #ff4d6a;
}

/* 签到卡片样式 */
.sign-in-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.sign-in-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sign-in-info {
  display: flex;
  flex-direction: column;
}

.sign-in-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.sign-in-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.sign-in-btn {
  background: #ff4d6a;
  color: #fff;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.sign-in-btn.signed {
  background: #ccc;
}

.sign-in-calendar {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.calendar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
}

.calendar-item.signed {
  color: #ff4d6a;
}

.calendar-item .date {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.calendar-item .points {
  font-size: 20rpx;
  color: #ff4d6a;
}
