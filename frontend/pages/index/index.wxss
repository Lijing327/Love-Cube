.container {
  min-height: 100vh;
  background: #f7f8f9;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 88rpx 30rpx 20rpx;
  background: #fff;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f7f8f9;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-right: 20rpx;
}

.search-input .placeholder {
  color: #999;
  font-size: 28rpx;
  margin-left: 10rpx;
}

.filter-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 轮播图 */
.banner {
  margin-top: 180rpx;
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 180rpx 30rpx 0;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 功能导航 */
.nav-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  background: #fff;
  margin-top: 30rpx;
  border-radius: 24rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #333;
}

/* 推荐用户 */
.section {
  margin-top: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.refresh-btn, .more-btn {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.refresh-btn text, .more-btn text {
  margin-left: 8rpx;
}

.recommend-scroll {
  white-space: nowrap;
}

.recommend-list {
  display: inline-flex;
  padding: 10rpx 0;
}

.recommend-item {
  width: 200rpx;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recommend-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.recommend-info {
  text-align: center;
}

.recommend-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.recommend-age {
  font-size: 24rpx;
  color: #999;
}

.recommend-tag {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #ff4d6a;
  background: rgba(255, 77, 106, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 新人推荐 */
.newcomer-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.newcomer-item {
  background: #f7f8f9;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
}

.newcomer-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.newcomer-info {
  flex: 1;
}

.newcomer-basic {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.newcomer-name {
  font-size: 28rpx;
  color: #333;
  margin-right: 12rpx;
}

.newcomer-age {
  font-size: 24rpx;
  color: #ff4d6a;
}

.newcomer-location {
  font-size: 24rpx;
  color: #999;
}

/* 筛选弹出层 */
.filter-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-reset {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.filter-reset text {
  margin-left: 8rpx;
}

.filter-section {
  margin-bottom: 40rpx;
}

.filter-section-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.range-text {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f7f8f9;
}

.tag-item.selected {
  color: #ff4d6a;
  background: rgba(255, 77, 106, 0.1);
}

.filter-footer {
  margin-top: auto;
  padding: 30rpx 0;
}
