/* 页面整体 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 头部标题 */
.header {
  width: 100%;
  text-align: center;
  padding: 20px 0;
  background: white;
  font-size: 18px;
  font-weight: bold;
  color: #333;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
}

/* 用户信息 */
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20px;
}

.avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-bottom: 10px;
}

.nickname {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

/* 登录按钮 */
.login-btn-container {
  width: 80%;
  margin-top: 20px;
}
