<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar" style="padding-top: {{menuBottom}}px;">
    <view class="nav-bar-content">
      <text class="nav-title">心动速配</text>
      <view class="filter-btn" bindtap="showFilter">
        <van-icon name="filter-o" size="20" />
      </view>
    </view>
  </view>

  <!-- 用户列表区域 -->
  <view class="match-area">
    <view class="user-grid">
      <view class="user-card" wx:for="{{matchList}}" wx:key="userid" bindtap="viewProfile" data-id="{{item.userid}}">
        <image class="user-image" src="{{item.profilePhoto || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-info">
          <view class="basic-info">
            <text class="name">{{item.username}}</text>
            <text class="gender">{{item.gender || '未知'}}</text>
          </view>
          <view class="detail-info">
            <text class="age">{{item.age}}岁</text>
            <text class="distance" wx:if="{{item.distance}}">{{item.distance}}km</text>
          </view>
          <view class="extra-info">
            <text class="occupation">{{item.occupation || '暂无职业'}}</text>
            <text class="location">{{item.location || '暂无地区'}}</text>
          </view>
        </view>
        <!-- 操作按钮 -->
        <view class="action-buttons" catchtap="stopPropagation">
          <view class="action-btn dislike" bindtap="onDislike" data-userid="{{item.userid}}">
            <van-icon name="close" size="40rpx" color="#ff4d6a" />
          </view>
          <view class="action-btn like" bindtap="onLike" data-userid="{{item.userid}}">
            <van-icon name="like" size="40rpx" color="#ff4d6a" />
          </view>
          <view class="action-btn super-like" bindtap="onSuperLike" data-userid="{{item.userid}}">
            <van-icon name="star" size="40rpx" color="#ff4d6a" />
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{matchList.length === 0}}">
      <image 
        src="/images/empty-matches.png" 
        mode="aspectFit"
        binderror="handleImageError"
        data-type="empty-image"
      />
      <text>暂无更多推荐</text>
    </view>
  </view>

  <!-- 筛选弹出层 -->
  <van-popup
    show="{{showFilterPopup}}"
    position="right"
    custom-style="width: 85%; height: 100%"
    bind:close="onCloseFilter"
    safe-area-inset-top
    round
  >
    <view class="filter-container">
      <view class="filter-content" style="margin-top: {{menuBottom}}px;">
        <view class="filter-section">
          <text class="filter-section-title">性别</text>
          <van-radio-group value="{{gender}}" bind:change="onGenderChange">
            <van-radio name="1">男生</van-radio>
            <van-radio name="2">女生</van-radio>
            <van-radio name="">全部</van-radio>
          </van-radio-group>
        </view>

        <!-- 操作按钮 -->
        <view class="filter-actions">
          <van-button type="default" block plain bind:tap="resetFilter">重置</van-button>
          <van-button type="primary" block bind:tap="applyFilter">确认</van-button>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- 推荐成功弹窗 -->
  <view class="match-success-popup" wx:if="{{showMatchSuccess}}">
    <view class="match-success-content">
      <image 
        class="success-image" 
        src="/images/match-success.png" 
        binderror="handleImageError" 
        data-type="success-image"
      />
      <text class="success-text">推荐成功！</text>
      <text class="success-sub-text">现在可以查看Ta的资料了</text>
      <view class="success-actions">
        <button class="profile-btn" bindtap="goToProfile">查看资料</button>
        <button class="close-btn" bindtap="closeMatchSuccess">关闭</button>
      </view>
    </view>
  </view>
</view>
