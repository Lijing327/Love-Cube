/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f8f8f8;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  border-bottom: 1rpx solid #eee;
}

.nav-bar-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.filter-btn {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 匹配区域 */
.match-area {
  margin-top: calc(44px + var(--status-bar-height));
  padding: 20rpx;
  min-height: calc(100vh - 44px - var(--status-bar-height));
}

/* 用户网格 */
.user-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 10rpx;
}

.user-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.user-image {
  width: 100%;
  height: 360rpx;
  object-fit: cover;
}

.user-info {
  padding: 16rpx;
}

.basic-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.age {
  font-size: 24rpx;
  color: #666;
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.occupation, .location {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-around;
  padding: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 筛选弹窗 */
.filter-container {
  height: 100%;
  background: #fff;
}

.filter-content {
  padding: 30rpx;
}

.filter-section {
  margin-bottom: 40rpx;
}

.filter-section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.filter-actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 匹配成功弹窗 */
.match-success-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.match-success-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.success-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.success-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.success-actions {
  display: flex;
  gap: 20rpx;
}

.chat-btn, .close-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.chat-btn {
  background: #ff4d6a;
  color: #fff;
}

.close-btn {
  background: #f5f5f5;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: #999;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

/* van-radio 样式覆盖 */
.van-radio__icon--checked .van-icon {
  background-color: #ff4d6a !important;
  border-color: #ff4d6a !important;
}

.van-button--primary {
  background-color: #ff4d6a !important;
  border-color: #ff4d6a !important;
}
