.container {
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.safe-area-top {
  height: var(--status-bar-height);
  background-color: #fff;
}

.header {
  background-color: #fff;
  border-bottom: 1px solid #e0e0e0;
  padding: 0 30rpx;
  z-index: 100;
}

.header-content {
  display: flex;
  align-items: center;
  height: 100rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #333;
}

.user-info {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.user-status {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.message-wall-content {
  flex: 1;
  padding: 0 30rpx;
}

.permission-notice {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.notice-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.notice-sub {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.message-list {
  padding: 20rpx 0;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.sender-name {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.message-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-wrap: break-word;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.empty-sub-text {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.message-input-area {
  background-color: #fff;
  border-top: 1px solid #e0e0e0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-container {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 10rpx 20rpx;
}

.message-input {
  flex: 1;
  min-height: 60rpx;
  font-size: 28rpx;
  background-color: transparent;
  border: none;
  outline: none;
}

.send-btn {
  width: 120rpx;
  height: 60rpx;
  background-color: #ddd;
  color: #999;
  border: none;
  border-radius: 30rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background-color: #ff4d6a;
  color: #fff;
}

.send-btn[disabled] {
  opacity: 0.5;
} 