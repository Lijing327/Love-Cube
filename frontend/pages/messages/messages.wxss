.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 页面头部 */
.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.mark-read-btn {
  background-color: #ff4d6a;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

/* 未读留言提示 */
.unread-notice {
  background: linear-gradient(135deg, #ff4d6a, #ff6b7a);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 106, 0.3);
}

.notice-content {
  display: flex;
  align-items: center;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.notice-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
}

/* 留言墙入口 */
.message-wall-entry {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.message-wall-entry:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.15);
}

.entry-content {
  display: flex;
  align-items: center;
}

.entry-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #ff4d6a, #ff6b7a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 32rpx;
  color: white;
}

.entry-info {
  flex: 1;
}

.entry-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.entry-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.entry-arrow {
  position: relative;
  display: flex;
  align-items: center;
}

.arrow-icon {
  font-size: 32rpx;
  color: #999;
  margin-right: 10rpx;
}

.unread-badge {
  background-color: #ff4d6a;
  color: white;
  border-radius: 50%;
  width: 32rpx;
  height: 32rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: -10rpx;
  top: -10rpx;
}

/* 功能说明 */
.feature-notice {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.notice-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-sub-text {
  font-size: 24rpx;
  color: #ccc;
}

/* 消息列表样式 */
.message-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.message-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.3s ease;
}

.message-item:last-child {
  border-bottom: none;
}

.message-item:active {
  background-color: #f8f8f8;
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.message-user-info {
  flex: 1;
}

.message-username {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.message-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.message-action-btn {
  background: none;
  border: none;
  color: #ff4d6a;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4d6a;
  border-radius: 50%;
  margin-left: 16rpx;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .container {
    padding: 16rpx;
  }
  
  .page-title {
    font-size: 32rpx;
  }
  
  .entry-title {
    font-size: 28rpx;
  }
  
  .notice-title {
    font-size: 26rpx;
  }
}