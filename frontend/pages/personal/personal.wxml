<!-- 页面容器 -->
<view class="container">
  <!-- 未登录状态 -->
  <block wx:if="{{!userInfo}}">
    <view class="login-required">
      <view class="login-icon">
        <van-icon name="user-o" size="60" color="#ccc" />
      </view>
      <view class="login-content">
        <text class="login-title">发现更多精彩</text>
        <text class="login-subtitle">登录后可以查看完整功能</text>
        <view class="login-benefits">
          <view class="benefit-item">
            <van-icon name="like-o" size="16" color="#ff4d6a" />
            <text>查看谁喜欢了你</text>
          </view>
          <view class="benefit-item">
            <van-icon name="chat-o" size="16" color="#ff4d6a" />
            <text>开始留言互动</text>
          </view>
          <view class="benefit-item">
            <van-icon name="friends-o" size="16" color="#ff4d6a" />
            <text>智能推荐系统</text>
          </view>
        </view>
        <van-button type="primary" color="#ff4d6a" bind:click="goToLogin">立即登录</van-button>
      </view>
    </view>
    
    <!-- 未登录状态下也可以使用的功能 -->
    <view class="guest-menu">
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-item-left">
          <van-icon name="info-o" color="#666666" size="22" />
          <text class="menu-text">关于我们</text>
        </view>
        <van-icon name="arrow" />
      </view>
      <view class="menu-item" bindtap="navigateToSettings">
        <view class="menu-item-left">
          <van-icon name="setting-o" color="#666666" size="22" />
          <text class="menu-text">设置</text>
        </view>
        <van-icon name="arrow" />
      </view>
    </view>
  </block>

  <!-- 正常内容 -->
  <block wx:else>
    <!-- 顶部背景 -->
    <view class="header-bg"></view>

    <!-- 个人信息卡片 -->
    <view class="profile-card">
      <!-- 顶部用户信息 -->
      <view class="user-info-top">
        <view class="avatar-section">
          <view class="avatar-wrapper" bindtap="onChooseAvatar">
            <van-image 
              class="avatar" 
              round 
              width="160rpx" 
              height="160rpx" 
              src="{{avatarUrl}}"
              fit="cover"
              use-loading-slot
              use-error-slot
            >
              <van-loading slot="loading" type="circular" size="20" vertical />
              <van-icon slot="error" name="photo-o" size="30" />
            </van-image>
            <view class="avatar-edit-btn">
              <van-icon name="photograph" size="14" />
            </view>
            <view class="vip-badge" wx:if="{{userInfo.isVip}}">VIP</view>
          </view>
        </view>
        
        <view class="user-details">
          <view class="user-name-section">
            <text class="user-nickname">{{userInfo.nickname || '未设置昵称'}}</text>
            <view class="user-tags">
              <text class="level-tag">Lv.{{userInfo.level || 1}}</text>
              <text class="constellation-tag" wx:if="{{userInfo.constellation}}">{{userInfo.constellation}}</text>
            </view>
          </view>
          
          <view class="user-location" wx:if="{{userInfo.location}}">
            <van-icon name="location-o" size="14" color="#999" />
            <text class="location-text">{{userInfo.location}}</text>
          </view>
          
          <text class="user-signature">{{userInfo.bio || '这个人很懒，什么都没写~'}}</text>
          
          <view class="profile-completion-mini">
            <text class="completion-text">资料完整度</text>
            <view class="completion-progress">
              <view class="progress-track">
                <view class="progress-fill" style="width: {{userInfo.completionRate || 0}}%"></view>
              </view>
              <text class="completion-percent">{{userInfo.completionRate || 0}}%</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 数据统计卡片 -->
      <view class="stats-cards">
        <view class="stat-card" bindtap="navigateToVisitors">
          <view class="stat-icon visitors-icon">
            <van-icon name="eye-o" size="20" />
          </view>
          <view class="stat-info">
            <text class="stat-number">{{userInfo.statistics.todayVisitors || 0}}</text>
            <text class="stat-label">今日访客</text>
          </view>
        </view>
        
        <view class="stat-card" bindtap="navigateToLikes">
          <view class="stat-icon likes-icon">
            <van-icon name="like-o" size="20" />
          </view>
          <view class="stat-info">
            <text class="stat-number">{{userInfo.statistics.newLikes || 0}}</text>
            <text class="stat-label">收到喜欢</text>
          </view>
        </view>
        
        <view class="stat-card" bindtap="navigateToMatches">
          <view class="stat-icon matches-icon">
            <van-icon name="friends-o" size="20" />
          </view>
          <view class="stat-info">
            <text class="stat-number">{{userInfo.statistics.newMatches || 0}}</text>
            <text class="stat-label">新增推荐</text>
          </view>
        </view>
      </view>

      <!-- 生活照片区域 -->
      <view class="photos-section" wx:if="{{userInfo.photos && userInfo.photos.length > 0}}">
        <view class="photos-header">
          <view class="photos-title-area">
            <van-icon name="photo-o" size="18" color="#ff4757" />
            <text class="photos-title">生活照片</text>
            <view class="photos-count-badge">{{userInfo.photos.length}}</view>
          </view>
          <view class="photos-manage-btn" bindtap="managePhotos">
            <text>管理</text>
            <van-icon name="arrow" size="12" />
          </view>
        </view>
        
        <scroll-view class="photos-scroll" scroll-x show-scrollbar="{{false}}">
          <view class="photos-grid">
            <image 
              wx:for="{{userInfo.photos}}" 
              wx:key="index"
              class="photo-thumbnail"
              src="{{item}}"
              mode="aspectFill"
              bindtap="previewPhoto"
              data-index="{{index}}"
              binderror="onPhotoError"
              bindload="onPhotoLoad"
              lazy-load="{{true}}"
            />
            <view class="photo-add-card" bindtap="managePhotos" wx:if="{{userInfo.photos.length < 9}}">
              <van-icon name="plus" size="20" color="#ccc" />
              <text class="add-text">添加</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 空状态生活照片 -->
      <view class="photos-empty" wx:else>
        <view class="photos-header">
          <view class="photos-title-area">
            <van-icon name="photo-o" size="18" color="#ff4757" />
            <text class="photos-title">生活照片</text>
          </view>
          <view class="photos-manage-btn" bindtap="managePhotos">
            <text>添加</text>
            <van-icon name="arrow" size="12" />
          </view>
        </view>
        <view class="photos-empty-content" bindtap="managePhotos">
          <van-icon name="photo-o" size="32" color="#ddd" />
          <text class="empty-text">展示你的精彩生活</text>
          <text class="empty-subtext">添加生活照片，让更多人了解你</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-list">
      <view class="menu-item" bindtap="editProfile">
        <view class="menu-item-left">
          <van-icon name="edit" color="#1989fa" size="22" />
          <text class="menu-text">编辑资料</text>
        </view>
        <van-icon name="arrow" />
      </view>
      
      <view class="menu-item" bindtap="viewVip">
        <view class="menu-item-left">
          <van-icon name="gem-o" color="#ff9900" size="22" />
          <text class="menu-text">会员中心</text>
        </view>
        <van-icon name="arrow" />
      </view>

      <view class="menu-item" bindtap="navigateToSettings">
        <view class="menu-item-left">
          <van-icon name="setting-o" color="#666666" size="22" />
          <text class="menu-text">设置</text>
        </view>
        <van-icon name="arrow" />
      </view>

      <view class="menu-item" bindtap="showAbout">
        <view class="menu-item-left">
          <van-icon name="info-o" color="#666666" size="22" />
          <text class="menu-text">关于我们</text>
        </view>
        <van-icon name="arrow" />
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </view>
  </block>
</view>

<!-- 地区选择器 -->
<van-popup
  show="{{ showLocationPicker }}"
  position="bottom"
  bind:close="onCloseLocationPicker"
>
  <van-area
    area-list="{{ areaList }}"
    value="{{ userInfo.locationCode }}"
    bind:confirm="onSelectLocation"
    bind:cancel="onCloseLocationPicker"
  />
</van-popup>