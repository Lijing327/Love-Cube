/* 页面整体布局 */
.container {
  min-height: 100vh;
  background-color: #f8f9fb;
  position: relative;
  padding-top: 120rpx;
}

/* 顶部背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #ff6b81, #ff4757);
  z-index: 1;
}

.header-title {
  color: #fff;
  font-size: 36rpx;
  text-align: center;
  font-weight: 600;
  padding-top: 60rpx;
}

/* 个人信息卡片 */
.profile-card {
  position: relative;
  z-index: 2;
  margin: 60rpx 60rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
}

/* 顶部用户信息区域 */
.user-info-top {
  padding: 50rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

.user-info-top::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="20" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="80" cy="40" r="1" fill="rgba(255,255,255,0.15)"/><circle cx="40" cy="80" r="1.5" fill="rgba(255,255,255,0.1)"/></svg>');
  pointer-events: none;
}

.avatar-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  position: relative;
  display: inline-block;
}

.avatar {
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.avatar-edit-btn {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: #ff4757;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.3);
}

.avatar-edit-btn .van-icon {
  color: #fff;
}

.vip-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.4);
}

.user-details {
  text-align: center;
}

.user-name-section {
  margin-bottom: 16rpx;
}

.user-nickname {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
}

.user-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.level-tag {
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.constellation-tag {
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.user-location {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.location-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-signature {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  margin-bottom: 24rpx;
  display: block;
}

.profile-completion-mini {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.completion-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
  display: block;
}

.completion-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #fff, rgba(255, 255, 255, 0.8));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.completion-percent {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 统计卡片 */
.stats-cards {
  display: flex;
  padding: 40rpx;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.stat-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.visitors-icon {
  background: linear-gradient(135deg, #74b9ff, #0984e3);
  color: #fff;
}

.likes-icon {
  background: linear-gradient(135deg, #fd79a8, #e84393);
  color: #fff;
}

.matches-icon {
  background: linear-gradient(135deg, #55a3ff, #003d82);
  color: #fff;
}

.stat-info {
  text-align: center;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #636e72;
  font-weight: 500;
}

/* 功能菜单 */
.menu-list {
  margin-top: 30rpx;
  margin-left: 60rpx;
  margin-right: 60rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #f1f2f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-text {
  font-size: 30rpx;
  color: #2c3e50;
  margin-left: 20rpx;
}

/* 退出登录按钮 */
.logout-btn {
  margin: 80rpx 60rpx;
  padding: 24rpx 0;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  color: #ff4757;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.logout-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f7f8fa;
  padding: 32rpx;
}

.error-text {
  margin: 24rpx 0;
  color: #666;
  font-size: 28rpx;
}

.debug-info {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.debug-info view {
  margin: 8rpx 0;
}

.debug-title {
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* 未登录状态 */
.login-required {
  margin: 60rpx 60rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
}

.login-icon {
  margin-bottom: 40rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #636e72;
  margin-bottom: 40rpx;
}

.login-benefits {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
  align-items: flex-start;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #ffeaa7;
  border-radius: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.benefit-item text {
  font-size: 26rpx;
  color: #2d3436;
  font-weight: 500;
}

/* 访客菜单 */
.guest-menu {
  margin: 0 60rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 生活照片区域 */
.photos-section, .photos-empty {
  padding: 40rpx;
  border-top: 1rpx solid #f1f2f6;
}

.photos-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.photos-title-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.photos-title {
  font-size: 30rpx;
  color: #2d3436;
  font-weight: 600;
}

.photos-count-badge {
  background: #ff4757;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
  min-width: 20rpx;
  text-align: center;
}

.photos-manage-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #636e72;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 1rpx solid #e9ecef;
}

.photos-scroll {
  white-space: nowrap;
}

.photos-grid {
  display: flex;
  gap: 16rpx;
  padding: 0 4rpx;
}

.photo-thumbnail {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  border: 2rpx solid #f8f9fa;
  transition: all 0.3s ease;
}

.photo-thumbnail:active {
  transform: scale(0.95);
}

.photo-add-card {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f8f9fa;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s ease;
}

.photo-add-card:active {
  background: #e9ecef;
  border-color: #ff4757;
}

.add-text {
  font-size: 20rpx;
  color: #999;
}

/* 空状态照片 */
.photos-empty-content {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  border: 2rpx dashed #e9ecef;
  transition: all 0.3s ease;
}

.photos-empty-content:active {
  border-color: #ff4757;
  background: #fff5f5;
}

.empty-text {
  font-size: 28rpx;
  color: #2d3436;
  font-weight: 500;
  margin: 16rpx 0 8rpx;
  display: block;
}

.empty-subtext {
  font-size: 24rpx;
  color: #636e72;
  display: block;
}


