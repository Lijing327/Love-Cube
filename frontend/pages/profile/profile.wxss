.container {
  min-height: 100vh;
  background: #f7f8f9;
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.nav-bar {
  background: #fff;
  padding-top: 88rpx; /* 状态栏高度 */
  border-bottom: 2rpx solid #f7f8f9;
}

.nav-bar-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-block {
  width: 60rpx;
  height: 60rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  text-align: center;
}

/* 头像编辑区 */
.avatar-section {
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar {
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.avatar-wrapper.uploading .avatar {
  opacity: 0.7;
}

.avatar-wrapper.uploading::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 56rpx;
  height: 56rpx;
  background: #ff4d6a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  transition: all 0.3s ease;
}

.avatar-wrapper:active .avatar-edit-icon {
  transform: scale(0.9);
}

.avatar-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
  transition: all 0.3s ease;
}

.avatar-wrapper.uploading + .avatar-tip {
  color: #ff4d6a;
}

/* 编辑区域通用样式 */
.edit-section {
  margin-top: 20rpx;
  background: #fff;
  padding: 0 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f7f8f9;
}

.form-group {
  padding: 20rpx 0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f7f8f9;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 性别选择器 */
.gender-select {
  flex: 1;
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #ddd;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

.gender-option.active {
  background: rgba(255, 77, 106, 0.1);
  border-color: #ff4d6a;
  color: #ff4d6a;
}

/* Picker样式 */
.picker-content {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.constellation {
  flex: 1;
  font-size: 28rpx;
  color: #999;
}

/* 个性签名编辑 */
.signature-input {
  width: 100%;
  height: 180rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

.signature-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 0;
}

/* 保存按钮 */
.save-btn-wrapper {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #ff4d6a;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  text-align: center;
}

/* 照片管理区域 */
.photos-section {
  margin-top: 20rpx;
  background: #fff;
  padding: 0 30rpx;
}

.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 30rpx 0;
}

.photo-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f7f8f9;
}

.photo-item .photo {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-item .delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.photo-item .delete-icon {
  color: #fff;
  font-size: 24rpx;
}

.add-photo {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  background: #f7f8f9;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-photo::before,
.add-photo::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #999;
}

.add-photo::before {
  width: 4rpx;
  height: 40rpx;
}

.add-photo::after {
  width: 40rpx;
  height: 4rpx;
}

.photos-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding-bottom: 20rpx;
}
