/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background: #f7f8f9;
}

.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  padding: 20rpx 0;
}

.search-results {
  margin-top: 120rpx;
  padding: 20rpx;
}

.user-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-basic {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 32rpx;
  color: #333;
  margin-right: 16rpx;
}

.user-age {
  font-size: 24rpx;
  color: #ff4d6a;
  background: rgba(255, 77, 106, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 24rpx;
  color: #666;
  background: #f0f2f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.user-location {
  font-size: 24rpx;
  color: #999;
}

.loading-status {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}