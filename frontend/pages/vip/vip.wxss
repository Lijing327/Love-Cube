.vip-container {
  padding: 20rpx;
  background: #f8f8f8;
}

/* 会员卡 */
.vip-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #ff9a3c, #ff6123);
  border-radius: 20rpx;
  color: #fff;
}

.vip-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.vip-info {
  display: flex;
  flex-direction: column;
}

.vip-name {
  font-size: 32rpx;
  font-weight: bold;
}

.vip-status {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 会员特权 */
.vip-benefits {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.benefit-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.benefit-item {
  width: 48%;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.benefit-text {
  margin-left: 10rpx;
  font-size: 26rpx;
}

/* 会员套餐 */
.vip-packages {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.package-list {
  display: flex;
  flex-direction: column;
}

.package-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.package-info {
  margin-left: 10rpx;
}

.package-name {
  font-size: 28rpx;
  font-weight: bold;
}

.package-price {
  font-size: 24rpx;
  color: #ff6123;
}

/* 支付按钮 */
.vip-action {
  margin-top: 40rpx;
  padding: 20rpx;
}
