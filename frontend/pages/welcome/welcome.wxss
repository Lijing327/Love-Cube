/* 页面整体布局 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #ffffff;
  padding: 20rpx;
}

/* 跳过按钮 */
.jump {
  position: absolute;
  top: 100rpx;
  left: 30rpx;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  cursor: pointer;
}



/* 让广告图占满整个屏幕 */
.image {
  width: 100vw;
  height: 100vh;
  object-fit: cover; /* 让图片填充屏幕，不变形 */
}

/* 欢迎文本 */
.welcome-text {
  margin-top: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d6a;
  text-align: center;
}
